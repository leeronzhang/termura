# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
*.xcuserstate
build/
DerivedData/

# Swift Package Manager
.build/
*.resolved
.swiftpm/
**/.swiftpm/

# Generated Xcode project
*.xcodeproj/

# Local-only workspace that bundles termura + termura-harness/iOS for parallel
# Xcode editing. Each developer can regenerate with their own paths.
Termura.xcworkspace/

# Tests (internal)
Tests/

# Harness directory: exclude private implementations, keep public stubs and protocols.
# Real implementations live in the private termura-harness Swift Package.
Sources/Termura/Harness/*
!Sources/Termura/Harness/HarnessModels.swift
!Sources/Termura/Harness/RuleFileRepositoryProtocol.swift
!Sources/Termura/Harness/HarnessViewModel+Stub.swift
!Sources/Termura/Harness/ExperienceCodifier+Stub.swift
!Sources/Termura/Harness/RemoteIntegration+Stub.swift

# CI/CD and internal build tooling
.github/
!.github/workflows/
!.github/workflows/ci.yml
Makefile
# scripts/* (not scripts/) so the negations below can re-include specific files —
# git ignores `!foo` when the parent directory itself is excluded by `scripts/`.
scripts/*
!scripts/check-signing-setup.sh
!scripts/check-version-sync.sh
!scripts/check-xcstrings-coverage.sh
!scripts/diagnose-codesign.sh
!scripts/pre-commit
!scripts/quality-gate.sh
!scripts/regen-all.sh
!scripts/sync-version-from-xcode.sh
project.yml
.swiftlint.yml
.swiftformat

# libghostty build artifacts (regenerated by scripts/build-libghostty.sh)
vendor/GhosttyKit.xcframework
vendor/.ghostty-build-stamp
vendor/ghostty-resources

# Internal docs
docs/

# Claude Code
CLAUDE.md
.claude/

# Landing page (separate repo)
landing/

# macOS
.DS_Store
.termura/

# Quality-gate / build transient logs (regenerated; never committed)
build_output.txt
lint_results.txt

# Local Xcode/SwiftPM working caches that some tooling drops in repo root
.cache/
.derived/
.home/
Library/
