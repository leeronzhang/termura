# Xcode
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
*.xcuserstate
build/
DerivedData/

# Swift Package Manager
.build/
*.resolved
.swiftpm/
**/.swiftpm/

# Generated Xcode project
*.xcodeproj/

# Local-only workspace bundle (per-machine).
# Each developer can regenerate with their own paths.
Termura.xcworkspace/

# Tests/ is fully tracked per CLAUDE.md §12.1 ("公开 target tests"). The
# pre-PR2 catch-all `Tests/` rule has been removed so newly added test
# files (Tests/TermuraTests/Harness/* from the harness migration) are
# visible to git without per-file negation gymnastics.

# Harness directory: previously a stub-only allowlist when the Mac harness
# implementation lived in the private repo. PR2 of the harness migration
# inlined the real implementation into Sources/Termura/Harness/ — the
# directory is now fully tracked, with no whitelist gymnastics.

# Public-package contract tests for the wire library. The line-22 `Tests/`
# rule was meant for the internal Termura app's tests, not the public
# package. Re-include the package's Tests/ directory + per-test whitelist
# so each unblocked file is reviewer-visible (bulk negation can land
# separately once previously-shadowed tests have their lint debt cleaned
# up; until then, intentional file-by-file unblock).
!Packages/TermuraRemoteKit/Tests/
!Packages/TermuraRemoteKit/Tests/TermuraRemoteClientTests/
!Packages/TermuraRemoteKit/Tests/TermuraRemoteServerTests/
Packages/TermuraRemoteKit/Tests/*/*
!Packages/TermuraRemoteKit/Tests/TermuraRemoteClientTests/TransportEventStreamTests.swift
!Packages/TermuraRemoteKit/Tests/TermuraRemoteClientTests/CloudKitClientTransportTests.swift
!Packages/TermuraRemoteKit/Tests/TermuraRemoteClientTests/CloudKitClientTransportCircuitBreakerTests.swift
!Packages/TermuraRemoteKit/Tests/TermuraRemoteClientTests/LANBrowserStateMappingTests.swift
!Packages/TermuraRemoteKit/Tests/TermuraRemoteServerTests/CloudKitReplyChannelEventTests.swift
!Packages/TermuraRemoteKit/Tests/TermuraRemoteServerTests/CloudKitTransportCircuitBreakerTests.swift

# LaunchAgent SPM executable test target — same rationale as TermuraRemoteKit
# above: Tests/ at line 23 was meant for the main app's internal test bundle,
# not the in-tree SPM packages.
!Packages/LaunchAgent/Tests/
!Packages/LaunchAgent/Tests/TermuraRemoteAgentTests/
!Packages/LaunchAgent/Tests/TermuraRemoteAgentTests/*.swift

# CI/CD and internal build tooling
.github/*
!.github/workflows/
!.github/workflows/ci.yml
!.github/PULL_REQUEST_TEMPLATE.md
Makefile
# scripts/* (not scripts/) so the negations below can re-include specific files —
# git ignores `!foo` when the parent directory itself is excluded by `scripts/`.
scripts/*
!scripts/baseline/
!scripts/check-baseline-drift.sh
!scripts/check-baseline-snapshots.sh
!scripts/check-entitlements-hygiene.sh
!scripts/check-error-localization.sh
!scripts/check-ios-permissions.sh
!scripts/check-mirrored-state-freshness.sh
!scripts/check-signing-setup.sh
!scripts/check-version-sync.sh
!scripts/check-xcstrings-coverage.sh
!scripts/diagnose-codesign.sh
!scripts/pre-commit
!scripts/quality-gate.sh
!scripts/regen-all.sh
!scripts/sync-version-from-xcode.sh
project.yml
.swiftlint.yml
.swiftformat

# libghostty build artifacts (regenerated by scripts/build-libghostty.sh)
vendor/GhosttyKit.xcframework
vendor/.ghostty-build-stamp
vendor/ghostty-resources

# Internal docs
docs/

# Claude Code
# CLAUDE.md was previously gitignored as part of the open-core cleanup
# (force-tracked entries were dropped). Post-PR4 the open-core boundary
# only protects against sibling-repo path leaks; CLAUDE.md is the canonical
# engineering policy and is tracked normally so changes go through review.
.claude/
# Claude Code's per-project auto-memory (cross-conversation state).
# Local-only; never tracked.
memory/

# Landing page (separate repo)
landing/

# macOS
.DS_Store
.termura/

# Quality-gate / build transient logs (regenerated; never committed)
build_output.txt
lint_results.txt

# Local Xcode/SwiftPM working caches that some tooling drops in repo root
.cache/
.derived/
.home/
Library/
