# SwiftFormat Configuration
# Aligned with .swiftlint.yml to prevent tool conflicts

--swiftversion 6.0

# Braces: K&R style (same line) — matches swiftlint opening_brace
--allman false

# Trailing commas: inline — matches swiftlint trailing_comma
--commas inline

# Wrap: preserve existing choices
--wraparguments preserve
--wrapparameters preserve
--wrapcollections preserve

# Self: remove redundant self (except where required by Swift concurrency)
--self remove
--selfrequired

# Unused arguments: closure unused args marked as _
--stripunusedargs closure-only

# Disable rules that conflict with our patterns
--disable andOperator
--disable initCoderUnavailable
# wrapMultilineStatementBraces conflicts with swiftlint opening_brace (K&R style)
--disable wrapMultilineStatementBraces

# Indent
--indent 4
--indentcase false
--ifdef no-indent
