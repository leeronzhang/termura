#!/bin/bash
# Termura Pre-commit Quality Gate
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

echo "🔍 Termura Pre-commit Quality Gate"
echo "======================================"

# --- 1. SwiftLint ---
echo "→ SwiftLint strict check..."
if command -v swiftlint &>/dev/null; then
    if ! swiftlint lint --strict --quiet 2>&1; then
        echo -e "${RED}✗ SwiftLint 检测到 error，提交被拒绝${NC}"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}✓ SwiftLint passed${NC}"
    fi
else
    echo -e "${YELLOW}⚠ swiftlint 未安装，跳过（brew install swiftlint）${NC}"
    WARNINGS=$((WARNINGS + 1))
fi

# --- 2. 强制解包检测（补充 SwiftLint 覆盖盲区）---
echo "→ Force unwrap/try/cast 检测..."
FORCE_FILES=$(grep -rn --include="*.swift" \
    -e '[^!]=\s*!\s*$' \
    -e 'try!' \
    -e 'as!' \
    Sources/Termura/ 2>/dev/null | \
    grep -v "// swiftlint:disable" | \
    grep -v "Tests/" || true)

if [ -n "$FORCE_FILES" ]; then
    echo -e "${RED}✗ 检测到强制解包/强制转换：${NC}"
    echo "$FORCE_FILES"
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}✓ 无强制解包${NC}"
fi

# --- 3. fatalError 检测 ---
echo "→ fatalError 检测..."
FATAL_FILES=$(grep -rn --include="*.swift" "fatalError(" Sources/Termura/ 2>/dev/null | \
    grep -v "// swiftlint:disable" || true)

if [ -n "$FATAL_FILES" ]; then
    echo -e "${RED}✗ 生产代码包含 fatalError：${NC}"
    echo "$FATAL_FILES"
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}✓ 无 fatalError${NC}"
fi

# --- 4. 遗留并发检测 ---
echo "→ 遗留并发 API 检测..."
DISPATCH_FILES=$(grep -rn --include="*.swift" \
    -e "DispatchQueue\.main\.async" \
    -e "DispatchQueue\.main\.asyncAfter" \
    -e "DispatchQueue\.global(" \
    Sources/Termura/ 2>/dev/null || true)

if [ -n "$DISPATCH_FILES" ]; then
    echo -e "${RED}✗ 检测到遗留 DispatchQueue 调用：${NC}"
    echo "$DISPATCH_FILES"
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}✓ 无遗留 DispatchQueue${NC}"
fi

# --- 5. try? 检测 ---
echo "→ try? 吞错检测..."
TRY_OPT=$(grep -rn --include="*.swift" "try?" Sources/Termura/ 2>/dev/null | \
    grep -v "// swiftlint:disable" || true)

if [ -n "$TRY_OPT" ]; then
    echo -e "${RED}✗ 检测到 try?（会吞没错误）：${NC}"
    echo "$TRY_OPT"
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}✓ 无 try?${NC}"
fi

# --- 6. 空 catch 块检测 ---
echo "→ 空 catch 块检测..."
EMPTY_CATCH=$(grep -rn --include="*.swift" -A1 "} catch {" Sources/Termura/ 2>/dev/null | \
    grep -B1 "^--$\|^}" | grep "} catch {" || true)

if [ -n "$EMPTY_CATCH" ]; then
    echo -e "${YELLOW}⚠ 疑似空 catch 块，请人工确认：${NC}"
    echo "$EMPTY_CATCH"
    WARNINGS=$((WARNINGS + 1))
else
    echo -e "${GREEN}✓ 无明显空 catch${NC}"
fi

# --- 7. 文件大小检测 ---
echo "→ 文件大小检测（≤ 300 行）..."
LARGE_FILES=""
while IFS= read -r -d '' file; do
    lines=$(wc -l < "$file")
    if [ "$lines" -gt 300 ]; then
        LARGE_FILES="$LARGE_FILES\n  $file ($lines 行)"
    fi
done < <(find Sources/Termura -name "*.swift" -print0 2>/dev/null)

if [ -n "$LARGE_FILES" ]; then
    echo -e "${YELLOW}⚠ 以下文件超过 300 行，建议拆分：${NC}"
    echo -e "$LARGE_FILES"
    WARNINGS=$((WARNINGS + 1))
else
    echo -e "${GREEN}✓ 文件大小正常${NC}"
fi

# --- 8. SwiftFormat（仅检查，不自动修改）---
echo "→ SwiftFormat 格式检测..."
if command -v swiftformat &>/dev/null; then
    if ! swiftformat --lint Sources/Termura/ --quiet 2>&1; then
        echo -e "${YELLOW}⚠ 代码格式不一致，请运行: swiftformat Sources/${NC}"
        WARNINGS=$((WARNINGS + 1))
    else
        echo -e "${GREEN}✓ SwiftFormat passed${NC}"
    fi
else
    echo -e "${YELLOW}⚠ swiftformat 未安装，跳过（brew install swiftformat）${NC}"
fi

# --- 结果汇总 ---
echo ""
echo "======================================"
if [ "$ERRORS" -gt 0 ]; then
    echo -e "${RED}✗ 提交被拒绝：$ERRORS 个 error，$WARNINGS 个 warning${NC}"
    echo "  修复上述问题后重新提交"
    exit 1
elif [ "$WARNINGS" -gt 0 ]; then
    echo -e "${YELLOW}⚠ 提交通过，但有 $WARNINGS 个 warning 建议处理${NC}"
    exit 0
else
    echo -e "${GREEN}✓ 所有检查通过，提交放行${NC}"
    exit 0
fi
