#!/usr/bin/env bash
# Termura Pre-commit Quality Gate
# Install:
#   cp scripts/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -euo pipefail

# ---------- Open-Core boundary check (CLAUDE.md §12.3) ----------
#
# Any tracked file in the public termura repo MUST NOT leak references to
# the private termura-harness sibling. Detected literals:
#   - "termura-harness/" or "../termura-harness/"
#   - private impl type names that only live in the private repo
#
# Allowed callers carry the literal in commentary or config; they're listed
# in WHITELIST_REGEX. Anything else trips the hook.

LEAK_PATTERN='(termura-harness/|RemoteServerHarness|RemoteEnvelopeRouter|RemoteAgentBridgeAssembly|RemoteAgentXPCClient|AppMailboxXPCBridge|AgentInjectedCloudKitIngress|TrustedSourceGate|RemoteAgentAutoConnector|AgentVirtualReplyChannel|RemoteIntegrationFactory)'
# Meta config / cross-repo orchestrator scripts and docs are allowed to mention
# the private repo path because their job is precisely to know about it.
# Code under Sources/ / Packages/ is not — that's where leaks would slip into
# release artefacts.
WHITELIST_REGEX='^(\.gitignore|CLAUDE\.md|README\.md|project\.yml\.example|scripts/pre-commit|scripts/pre-commit-private|scripts/quality-gate\.sh|scripts/regen-all\.sh|scripts/check-open-core\.sh|memory/|Sources/Termura/Harness/.*\+Stub\.swift|Sources/Termura/Harness/HarnessViewModel\+Stub\.swift|Sources/Termura/Harness/HarnessModels\.swift|Sources/Termura/Harness/RuleFileRepositoryProtocol\.swift|Tests/TermuraTests/Harness/.*\.swift|Packages/.*\.swift)$'

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"
LEAKS=""
while IFS= read -r file; do
    [ -z "$file" ] && continue
    [ ! -f "$file" ] && continue
    if echo "$file" | grep -qE "$WHITELIST_REGEX"; then
        continue
    fi
    if grep -qE "$LEAK_PATTERN" "$file" 2>/dev/null; then
        MATCHES="$(grep -nE "$LEAK_PATTERN" "$file" | head -3)"
        LEAKS="${LEAKS}${file}:\n${MATCHES}\n"
    fi
done <<< "$STAGED_FILES"

if [ -n "$LEAKS" ]; then
    echo "✘ Open-Core boundary violation: private path/type names found in tracked-eligible file(s):"
    printf '%b\n' "$LEAKS"
    echo ""
    echo "Resolve one of:"
    echo "  1. Move the file to termura-harness/ (private repo)"
    echo "  2. Rename the symbol to avoid the private impl name"
    echo "  3. Add the file to WHITELIST_REGEX in scripts/pre-commit (only for meta files)"
    echo ""
    echo "See CLAUDE.md §12 'Open-Core Boundary' for the full rule."
    exit 1
fi

# ---------- Forbidden force-add of private-path-bearing artifacts ----------
#
# Termura.xcworkspace/ and project.yml are gitignored because they encode
# per-machine signing config or private-repo paths. Catch the case where
# someone bypasses gitignore with `git add -f`. As of PR9.x project.yml is
# fully untracked: each machine regenerates it via `cp project.yml.example
# project.yml`. Never re-add the materialized project.yml to git history.

FORBIDDEN_FORCED="$(echo "$STAGED_FILES" | grep -E '^(Termura\.xcworkspace/|project\.yml$)' || true)"
if [ -n "$FORBIDDEN_FORCED" ]; then
    echo "✘ Refusing to commit gitignored open-core boundary artifacts:"
    echo "$FORBIDDEN_FORCED" | sed 's/^/  /'
    echo "These files contain machine-local or private-repo paths. They must"
    echo "stay gitignored — never use 'git add -f' on them."
    exit 1
fi

# ---------- Quality gate ----------
bash scripts/quality-gate.sh --staged
