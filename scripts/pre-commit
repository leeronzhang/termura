#!/usr/bin/env bash
# Termura Pre-commit Quality Gate
# Install:
#   cp scripts/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -euo pipefail

# ---------- Open-Core boundary check (CLAUDE.md §12.3) ----------
#
# Any tracked file in the public termura repo MUST NOT leak references to
# the private termura-harness sibling. Detected literals:
#   - "termura-harness/" or "../termura-harness/"
#   - private impl type names that only live in the private repo
#
# Allowed callers carry the literal in commentary or config; they're listed
# in WHITELIST_REGEX. Anything else trips the hook.

LEAK_PATTERN='(termura-harness/|RemoteServerHarness|RemoteEnvelopeRouter)'
WHITELIST_REGEX='^(\.gitignore|CLAUDE\.md|README\.md|project\.yml|project\.yml\.example|scripts/pre-commit|scripts/quality-gate\.sh|memory/|Sources/Termura/Harness/.*\+Stub\.swift|Sources/Termura/Harness/HarnessViewModel\+Stub\.swift|Sources/Termura/Harness/HarnessModels\.swift|Sources/Termura/Harness/RuleFileRepositoryProtocol\.swift|Tests/TermuraTests/Harness/.*\.swift|Packages/.*\.swift)$'

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"
LEAKS=""
while IFS= read -r file; do
    [ -z "$file" ] && continue
    [ ! -f "$file" ] && continue
    if echo "$file" | grep -qE "$WHITELIST_REGEX"; then
        continue
    fi
    if grep -qE "$LEAK_PATTERN" "$file" 2>/dev/null; then
        MATCHES="$(grep -nE "$LEAK_PATTERN" "$file" | head -3)"
        LEAKS="${LEAKS}${file}:\n${MATCHES}\n"
    fi
done <<< "$STAGED_FILES"

if [ -n "$LEAKS" ]; then
    echo "✘ Open-Core boundary violation: private path/type names found in tracked-eligible file(s):"
    printf '%b\n' "$LEAKS"
    echo ""
    echo "Resolve one of:"
    echo "  1. Move the file to termura-harness/ (private repo)"
    echo "  2. Rename the symbol to avoid the private impl name"
    echo "  3. Add the file to WHITELIST_REGEX in scripts/pre-commit (only for meta files)"
    echo ""
    echo "See CLAUDE.md §12 'Open-Core Boundary' for the full rule."
    exit 1
fi

# ---------- Forbidden force-add of private-path-bearing artifacts ----------
#
# Termura.xcworkspace/ is gitignored because it references the private
# `../termura-harness/` repo via a per-machine workspace file. Catch the
# case where someone bypasses gitignore with `git add -f`. `project.yml`
# is intentionally NOT in this list: the repo has historically tracked it
# (carrying the `../termura-harness/LaunchAgent` build-script path inside),
# and migrating it to gitignored is a separate repo-governance task.

FORBIDDEN_FORCED="$(echo "$STAGED_FILES" | grep -E '^Termura\.xcworkspace/' || true)"
if [ -n "$FORBIDDEN_FORCED" ]; then
    echo "✘ Refusing to commit gitignored open-core boundary artifacts:"
    echo "$FORBIDDEN_FORCED" | sed 's/^/  /'
    echo "These files contain machine-local or private-repo paths. They must"
    echo "stay gitignored — never use 'git add -f' on them."
    exit 1
fi

# ---------- Quality gate ----------
bash scripts/quality-gate.sh --staged
