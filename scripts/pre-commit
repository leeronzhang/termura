#!/usr/bin/env bash
# Termura Pre-commit Quality Gate
# Install:
#   cp scripts/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -euo pipefail

# ---------- Open-Core boundary check (CLAUDE.md §12.3) ----------
#
# Any tracked file in the public repo MUST NOT carry the literal sibling-
# repo path. The detector is intentionally PATH-ONLY:
#
#   - Path leaks (`termura-harness/`) have NO legitimate use in tracked
#     source code outside this script and `regen-all.sh` (both
#     self-excluded below).
#
#   - Type-name protection is delegated to code review (CODEOWNERS +
#     required reviewer). Façade routing across the `#if HARNESS_ENABLED`
#     boundary in `Sources/Termura/Harness/RemoteIntegration+Stub.swift`
#     physically must name a private-impl symbol; a grep would either
#     reject every legitimate stub edit, or be silently bypassed by a
#     rename. Review catches the semantics; grep does not.
#
# DO NOT extend this regex with type names. If a new leak class
# appears (e.g. a new tracked file mistakenly hardcodes the sibling
# repo path), fix the file — don't extend the pattern.
LEAK_PATTERN='termura-harness'
# Self-exclude the three scanner / cross-repo orchestrator scripts that
# physically MUST embed the leak literal because that IS their job:
#   - scripts/pre-commit       — a scanner that can't grep its own
#                                 pattern is non-functional
#   - scripts/regen-all.sh     — cross-repo xcodegen orchestrator must
#                                 `cd` into the sibling repo's path
#   - scripts/quality-gate.sh  — `--include-private` mode must `cd`
#                                 into the sibling repo to run paired
#                                 quality checks
# This is a physical-self-reference exclusion, not a policy whitelist:
# any attempt to extend SELF_EXCLUDE_FILES with other entries must be
# rejected at review (see CLAUDE.md §12.3).
SELF_EXCLUDE_FILES='^(scripts/pre-commit|scripts/regen-all\.sh|scripts/quality-gate\.sh)$'

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"
LEAKS=""
while IFS= read -r file; do
    [ -z "$file" ] && continue
    [ ! -f "$file" ] && continue
    if echo "$file" | grep -qE "$SELF_EXCLUDE_FILES"; then
        continue
    fi
    if grep -qE "$LEAK_PATTERN" "$file" 2>/dev/null; then
        MATCHES="$(grep -nE "$LEAK_PATTERN" "$file" | head -3)"
        LEAKS="${LEAKS}${file}:\n${MATCHES}\n"
    fi
done <<< "$STAGED_FILES"

if [ -n "$LEAKS" ]; then
    echo "✘ Open-Core boundary violation: private repo path found in tracked file(s):"
    printf '%b\n' "$LEAKS"
    echo ""
    echo "Resolve one of:"
    echo "  1. Move the file to the private repo"
    echo "  2. Rewrite the literal — neutral wording works for prose,"
    echo "     env var indirection works for scripts"
    echo ""
    echo "Do NOT add the file to SELF_EXCLUDE_FILES — that list is"
    echo "reserved for the two scanner scripts that must self-reference."
    echo "See CLAUDE.md §12.3 'Open-Core Boundary' for the full rule."
    exit 1
fi

# ---------- Forbidden force-add of private-path-bearing artifacts ----------
#
# Termura.xcworkspace/ and project.yml are gitignored because they encode
# per-machine signing config or private-repo paths. Catch the case where
# someone bypasses gitignore with `git add -f`. As of PR9.x project.yml is
# fully untracked: each machine regenerates it via `cp project.yml.example
# project.yml`. Never re-add the materialized project.yml to git history.

FORBIDDEN_FORCED="$(echo "$STAGED_FILES" | grep -E '^(Termura\.xcworkspace/|project\.yml$)' || true)"
if [ -n "$FORBIDDEN_FORCED" ]; then
    echo "✘ Refusing to commit gitignored open-core boundary artifacts:"
    echo "$FORBIDDEN_FORCED" | sed 's/^/  /'
    echo "These files contain machine-local or private-repo paths. They must"
    echo "stay gitignored — never use 'git add -f' on them."
    exit 1
fi

# ---------- Quality gate ----------
bash scripts/quality-gate.sh --staged
