#!/usr/bin/env bash
# Termura Pre-commit Quality Gate (private iOS repo side)
# Single source of truth — invoked from the private iOS repo's
# .git/hooks/pre-commit via the wrapper in that repo's scripts/pre-commit.
# Run with the private repo as cwd.
#
# Mirrors scripts/pre-commit's intent but inverted:
#   - Reverse open-core leak: private repo MUST NOT redeclare public-stub
#     protocol or Null* implementation names. The single source of truth lives
#     in Sources/Termura/Harness/RemoteIntegration+Stub.swift in the public
#     repo; redeclaring those names here means duplicate symbols at link time
#     and a broken boundary.
#   - Quality gate: same SwiftLint / SwiftFormat / forbidden patterns / file
#     budget / suppression / mock placement / task ownership rules as public
#     code, applied to whatever the user staged in this private repo.

set -euo pipefail

# Resolve repo locations. The hook always runs with cwd at the private repo
# root because git invokes pre-commit there.
PRIVATE_REPO_ROOT="$(pwd)"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PUBLIC_REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

if [[ ! -f "$PUBLIC_REPO_ROOT/.swiftlint.yml" || ! -f "$PUBLIC_REPO_ROOT/.swiftformat" ]]; then
    echo "FAIL: public Termura repo not found at $PUBLIC_REPO_ROOT (missing config files)"
    echo "  The private iOS repo's quality gate is sourced from the public repo's"
    echo "  scripts/. Make sure the public Termura checkout is the sibling of"
    echo "  this private repo."
    exit 1
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

record_failure() { ERRORS=$((ERRORS + 1)); }
record_warning() { WARNINGS=$((WARNINGS + 1)); }

run_gate_check() {
    local label="$1"
    shift
    echo "-> ${label}..."
    set +e
    "$@"
    local status=$?
    set -e
    case "$status" in
        0) ;;
        3) record_warning ;;
        *) record_failure ;;
    esac
}

echo "Termura Quality Gate (private)"
echo "  cwd: $PRIVATE_REPO_ROOT"
echo "  config: $PUBLIC_REPO_ROOT"
echo "======================================"

# ---------- Direct-commit-to-main guard (CLAUDE.md §15.1) ----------
#
# Mirror of the public repo's guard. main is the published baseline; new
# work must land via merge / cherry-pick / revert / rebase from a feat
# branch. Manual `git commit` on main is rejected.
#
# Escape hatch: TERMURA_ALLOW_MAIN_COMMIT=1.
if [[ -z "${TERMURA_ALLOW_MAIN_COMMIT:-}" ]]; then
    CURRENT_BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
    if [[ "$CURRENT_BRANCH" == "main" ]]; then
        GIT_DIR_PATH="$(git rev-parse --git-dir)"
        if [[ ! -f "$GIT_DIR_PATH/MERGE_HEAD"        && \
              ! -f "$GIT_DIR_PATH/CHERRY_PICK_HEAD"  && \
              ! -f "$GIT_DIR_PATH/REVERT_HEAD"       && \
              ! -d "$GIT_DIR_PATH/rebase-merge"      && \
              ! -d "$GIT_DIR_PATH/rebase-apply" ]]; then
            echo "✘ §15.1 violation: manual commit to main is forbidden." >&2
            echo "  Switch to a feat branch:  git switch -c feat/<theme>" >&2
            echo "  Merges / cherry-picks / reverts / rebases on main are allowed." >&2
            echo "  Emergency override (use sparingly):  TERMURA_ALLOW_MAIN_COMMIT=1 git commit ..." >&2
            exit 1
        fi
    fi
fi

# ---------- Reverse open-core leak ----------
# Public stub names that must not be redeclared in the private repo. The
# public Sources/Termura/Harness/RemoteIntegration+Stub.swift owns each
# protocol and Null* implementation; private code provides concrete impls
# only.
REVERSE_LEAK_PATTERN='\b(protocol\s+(RemoteIntegration|RemoteSessionsAdapter|RemoteAgentBridgeLifecycle)\b|class\s+Null(RemoteIntegration|RemoteSessionsAdapter|RemoteAgentBridgeLifecycle)\b)'

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"
LEAKS=""
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    [[ ! -f "$file" ]] && continue
    case "$file" in
        *.swift) ;;
        *) continue ;;
    esac
    if grep -qE "$REVERSE_LEAK_PATTERN" "$file" 2>/dev/null; then
        MATCHES="$(grep -nE "$REVERSE_LEAK_PATTERN" "$file" | head -3)"
        LEAKS="${LEAKS}${file}:\n${MATCHES}\n"
    fi
done <<< "$STAGED_FILES"

if [[ -n "$LEAKS" ]]; then
    echo -e "${RED}✘ Reverse open-core boundary violation:${NC} private repo is redeclaring a public stub name"
    printf '%b\n' "$LEAKS"
    echo ""
    echo "Resolve one of:"
    echo "  1. Delete the duplicate declaration — the public repo owns it"
    echo "  2. Rename the symbol in private code so it no longer collides"
    echo ""
    echo "See CLAUDE.md §12 'Open-Core Boundary' for the full rule."
    exit 1
fi

# ---------- Build the staged Swift file list ----------
# Tests live under `*Tests/`. The shared SwiftLint config (`.swiftlint.yml`)
# only declares production sources in its `included` list, so a manual
# `swiftlint lint <file>` invocation against test files would apply rules
# that were never meant for them (force_unwrapping in expectation
# fixtures, file_length on test suites, etc.). Skip test paths the same
# way the public quality-gate does — fix-it noise on tests would push
# users toward `--no-verify`.
STAGED_SWIFT=()
while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    [[ ! -f "$f" ]] && continue
    case "$f" in
        *.swift) ;;
        *) continue ;;
    esac
    case "$f" in
        */Tests/*|*Tests/*|*Test.swift|*Tests.swift) continue ;;
    esac
    STAGED_SWIFT+=("$f")
done <<< "$STAGED_FILES"

if [[ ${#STAGED_SWIFT[@]} -eq 0 ]]; then
    echo -e "${GREEN}OK: No staged Swift changes; skipping format / lint checks.${NC}"
    exit 0
fi

# ---------- SwiftLint ----------
echo "-> SwiftLint strict check..."
if command -v swiftlint >/dev/null 2>&1; then
    SWIFTLINT_CACHE_PATH="${TMPDIR:-/tmp}/termura-swiftlint.cache"
    if ! swiftlint lint --strict --quiet --cache-path "$SWIFTLINT_CACHE_PATH" \
        --config "$PUBLIC_REPO_ROOT/.swiftlint.yml" "${STAGED_SWIFT[@]}"; then
        echo -e "${RED}FAIL: SwiftLint errors detected.${NC}"
        record_failure
    else
        echo -e "${GREEN}OK: SwiftLint passed${NC}"
    fi
else
    echo -e "${YELLOW}WARN: swiftlint not installed (brew install swiftlint)${NC}"
    record_warning
fi

# ---------- SwiftFormat ----------
echo "-> SwiftFormat check..."
if command -v swiftformat >/dev/null 2>&1; then
    if ! swiftformat --lint --quiet --config "$PUBLIC_REPO_ROOT/.swiftformat" "${STAGED_SWIFT[@]}"; then
        echo -e "${RED}FAIL: SwiftFormat violations detected.${NC}"
        record_failure
    else
        echo -e "${GREEN}OK: SwiftFormat passed${NC}"
    fi
else
    echo -e "${YELLOW}WARN: swiftformat not installed (brew install swiftformat)${NC}"
    record_warning
fi

# ---------- Forbidden Swift patterns (Python) ----------
echo "-> Forbidden Swift pattern checks..."
if ! FORBIDDEN_OUTPUT="$(python3 - "${STAGED_SWIFT[@]}" <<'PYEOF'
import pathlib
import re
import sys

paths = [pathlib.Path(p) for p in sys.argv[1:]]
checks = [
    ("force unwrap / try! / as!", [
        re.compile(r"\btry!"),
        re.compile(r"\bas!"),
        re.compile(r"=\s*!\s*$"),
    ]),
    ("fatalError in production code", [re.compile(r"\bfatalError\s*\(")]),
    ("try? error swallowing", [re.compile(r"\btry\?")]),
    ("legacy DispatchQueue API", [
        re.compile(r"DispatchQueue\.main\.async\b"),
        re.compile(r"DispatchQueue\.main\.asyncAfter\b"),
        re.compile(r"DispatchQueue\.global\s*\("),
    ]),
]

violations: list[str] = []
for path in paths:
    if not path.exists():
        continue
    with path.open(encoding="utf-8") as fh:
        for lineno, line in enumerate(fh, start=1):
            stripped = line.strip()
            if stripped.startswith("//") or "swiftlint:disable" in line:
                continue
            for description, patterns in checks:
                if any(pattern.search(line) for pattern in patterns):
                    violations.append(f"{description}|{path}:{lineno}: {line.rstrip()}")

if violations:
    grouped: dict[str, list[str]] = {}
    for entry in violations:
        key, detail = entry.split("|", 1)
        grouped.setdefault(key, []).append(detail)
    for key, details in grouped.items():
        print(f"FAIL: {key}")
        for detail in details:
            print(f"  {detail}")
    sys.exit(1)

print("OK: No forbidden Swift patterns found")
PYEOF
)"
then
    echo "$FORBIDDEN_OUTPUT"
    record_failure
else
    echo "$FORBIDDEN_OUTPUT"
fi

# ---------- Per-staged-file scoped checks ----------
# Run suppression / file-size / forbidden-pattern equivalents via per-file
# inspection rather than whole-tree helpers. The whole-tree helpers
# (`check-suppressions.sh`, `check-file-size.sh`, etc.) are designed for
# `bash scripts/quality-gate.sh` full runs and would otherwise re-flag
# unstaged dirty files (e.g. RemoteStore.swift's known structural debt) on
# every unrelated commit. SwiftLint --strict already covers file_length /
# type_body / function_body via the rules in .swiftlint.yml, so the
# pre-commit gate stays focused on staged content only.

# Suppression check: forbid swiftlint:disable / swiftformat:disable /
# @preconcurrency / nonisolated(unsafe) callback storage in any staged file.
SUPPRESSIONS_FOUND=""
# `@preconcurrency import M` is allowed (CLAUDE.md §4.6 — ObjC interop);
# only the declaration form `@preconcurrency class/func/...` is a
# suppression. Same regex shape as scripts/check-suppressions.sh so the
# two paths can never drift.
for f in "${STAGED_SWIFT[@]}"; do
    matches="$(grep -nE 'swiftlint:(disable|enable)|swiftformat:(disable|enable|ignore|off|on)|swift-format:(disable|enable|ignore|off|on)|@preconcurrency[[:space:]]+(class|struct|actor|enum|protocol|func|var|let|extension)\b|nonisolated\(unsafe\).*var .*->' "$f" 2>/dev/null || true)"
    if [[ -n "$matches" ]]; then
        SUPPRESSIONS_FOUND="${SUPPRESSIONS_FOUND}${f}:\n${matches}\n"
    fi
done
if [[ -n "$SUPPRESSIONS_FOUND" ]]; then
    echo "-> Suppression check..."
    echo -e "${RED}FAIL: suppression annotations in staged files:${NC}"
    printf '%b' "$SUPPRESSIONS_FOUND" | sed 's/^/  /'
    record_failure
fi

echo ""
echo "======================================"
if [[ $ERRORS -gt 0 ]]; then
    echo -e "${RED}FAIL: Quality gate (private) failed with ${ERRORS} error(s), ${WARNINGS} warning(s).${NC}"
    exit 1
fi

if [[ $WARNINGS -gt 0 ]]; then
    echo -e "${YELLOW}WARN: Quality gate (private) passed with ${WARNINGS} warning(s).${NC}"
else
    echo -e "${GREEN}OK: All quality checks passed${NC}"
fi
